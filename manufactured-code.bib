
@article{genz_why_2001,
	title = {Why advocates need to rethink manufactured housing},
	volume = {12},
	issn = {1051-1482},
	url = {https://doi.org/10.1080/10511482.2001.9521411},
	doi = {10.1080/10511482.2001.9521411},
	abstract = {Manufactured homes are a major source of unsubsidized, low‐cost housing. Accounting for 30 percent of new homes nationwide, they are especially popular in the South. Seventy percent of new manufactured homes are placed on the homeowner's land. The U.S. homeownership rate would drop by almost five percentage points if owners of manufactured homes were excluded. Bias contributes to neglect of issues important to these households, which typically have low incomes and little wealth. Inattention has perpetuated bad bargains in financing, legal protection, quality, and appreciation. The “personal property” paradigm isolates manufactured housing from housing finance and contributes to depreciation. Research should identify factors contributing to appreciation, and mainstream mortgage lenders should enter the market to offer cheaper, more transparent financing. Education would help consumers navigate the marketplace. By incorporating manufactured housing into consumer‐oriented, wealth‐building developments, nonprofits could take the lead in offering buyers real value, not just low price.},
	number = {2},
	urldate = {2025-01-31},
	journal = {Housing Policy Debate},
	publisher = {Routledge},
	author = {Genz, Richard},
	month = jan,
	year = {2001},
	note = {\_eprint: https://doi.org/10.1080/10511482.2001.9521411},
	keywords = {Homeownership, Low‐income housing, Manufactured housing, Policy},
	pages = {393--414},
}

@article{levinson_how_2016,
	title = {How {Much} {Energy} {Do} {Building} {Energy} {Codes} {Save}? {Evidence} from {California} {Houses}},
	volume = {106},
	issn = {0002-8282},
	shorttitle = {How {Much} {Energy} {Do} {Building} {Energy} {Codes} {Save}?},
	url = {https://www.aeaweb.org/articles?id=10.1257/aer.20150102},
	doi = {10.1257/aer.20150102},
	abstract = {Regulations governing the energy efficiency of new buildings have become a cornerstone of US environmental policy. California enacted the first such codes in 1978 and has tightened them every few years since. I evaluate the resulting energy savings three ways: comparing energy used by houses constructed under different standards, controlling for building and occupant characteristics; examining how energy use varies with outdoor temperatures; and comparing energy used by houses of different vintages in California to that same difference in other states. All three approaches yield estimated energy savings significantly short of those projected when the regulations were enacted.},
	language = {en},
	number = {10},
	urldate = {2026-04-09},
	journal = {American Economic Review},
	author = {Levinson, Arik},
	month = oct,
	year = {2016},
	keywords = {Distributional Effects, Employment Effects, Energy: Government Policy, Energy: Government Policy, Valuation of Environmental Effects, Pollution Control Adoption and Costs, Pollution Control Adoption and Costs; Distributional Effects; Employment Effects, Valuation of Environmental Effects},
	pages = {2867--2894},
	file = {Full Text PDF:/home/colin/snap/zotero-snap/common/Zotero/storage/CYWDJSKT/Levinson - 2016 - How Much Energy Do Building Energy Codes Save Evidence from California Houses.pdf:application/pdf},
}

@article{simmons_economic_2018,
	chapter = {Articles},
	title = {Economic {Effectiveness} of {Implementing} a {Statewide} {Building} {Code}: {The} {Case} of {Florida}},
	volume = {94},
	copyright = {© 2018 by the Board of Regents of the University of Wisconsin System},
	issn = {0023-7639, 1543-8325},
	shorttitle = {Economic {Effectiveness} of {Implementing} a {Statewide} {Building} {Code}},
	url = {https://le.uwpress.org/content/94/2/155},
	doi = {10.3368/le.94.2.155},
	abstract = {Hurricane Andrew revealed inadequate construction practices were utilized in Florida for decades. In response, Florida adopted a new statewide code—the 2001 Florida Building Code (FBC)—which became one of the strictest in the nation. We use 10 years of paid insured loss data to show that the FBC reduced windstorm losses by up to 72\%, then use our results to conduct a benefit-cost analysis (BCA). The FBC passes the BCA by a margin of \$6 in full reduced loss to \$1 of added cost, with a payback period of approximately 8 years. (JEL Q54, Q58)},
	language = {en},
	number = {2},
	urldate = {2026-04-09},
	journal = {Land Economics},
	publisher = {University of Wisconsin Press},
	author = {Simmons, Kevin M. and Czajkowski, Jeffrey and Done, James M.},
	month = may,
	year = {2018},
	pages = {155--174},
}

@article{simmons_manufactured_2008,
	title = {Manufactured home building regulations and the {February} 2, 2007 {Florida} tornadoes},
	volume = {46},
	issn = {1573-0840},
	url = {https://doi.org/10.1007/s11069-007-9192-4},
	doi = {10.1007/s11069-007-9192-4},
	abstract = {The Department of Housing and Urban Development (HUD) and the state of Florida implemented new wind load and tie-down regulations for manufactured homes following Hurricane Andrew. This article examines the effect of the new regulations on the likelihood that occupants of mobile homes would survive a tornado. On February 2, 2007, three tornadoes struck central Florida, resulting in 21 deaths in Lake County, all in manufactured homes. The deaths occurred almost exclusively in homes rated as leveled by the county tax appraiser. Manufactured homes built to the new regulations, however, were significantly less likely to be leveled. Regression analysis finds that manufactured homes built to the post-Andrew requirements were 79\% less likely to be leveled than homes built prior to the HUD Code in 1976, and 68\% less likely to be leveled than homes built after 1976 but before the 1994 wind load regulations. Construction of all manufactured homes in the tornado paths to the wind load and tie-down requirements could have reduced fatalities by 70\%.},
	language = {en},
	number = {3},
	urldate = {2026-04-09},
	journal = {Natural Hazards},
	author = {Simmons, Kevin M. and Sutter, Daniel},
	month = sep,
	year = {2008},
	keywords = {Natural hazards, Tornadoes, Fatalities, Manufactured homes},
	pages = {415--425},
	file = {Full Text PDF:/home/colin/snap/zotero-snap/common/Zotero/storage/GLHDRV6B/Simmons and Sutter - 2008 - Manufactured home building regulations and the February 2, 2007 Florida tornadoes.pdf:application/pdf},
}

