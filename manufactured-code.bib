	shorttitle = {How {Much} {Energy} {Do} {Building} {Energy} {Codes} {Save}?},
	url = {https://www.aeaweb.org/articles?id=10.1257/aer.20150102},
	doi = {10.1257/aer.20150102},
	abstract = {Regulations governing the energy efficiency of new buildings have become a cornerstone of US environmental policy. California enacted the first such codes in 1978 and has tightened them every few years since. I evaluate the resulting energy savings three ways: comparing energy used by houses constructed under different standards, controlling for building and occupant characteristics; examining how energy use varies with outdoor temperatures; and comparing energy used by houses of different vintages in California to that same difference in other states. All three approaches yield estimated energy savings significantly short of those projected when the regulations were enacted.},
	language = {en},
	number = {10},
	urldate = {2026-04-09},
	journal = {American Economic Review},
